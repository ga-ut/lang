import ast

type Token = { tag: i32, start: i32, end: i32, int_val: i32 }

type TokTable = { buf: Bytes, count: i32 }

type ScanState = { src: Str, i: i32, n: i32 }

type TokenRes = { tok: Token, state: ScanState }

type Parser = { src: Str, toks: TokTable, idx: i32 }

type TableRes = { table: Table, idx: i32 }
type ParseRes = { p: Parser, ast: Ast, idx: i32, start: i32, end: i32 }
type ParseListRes = { p: Parser, ast: Ast, list: i32 }
type ListRes = { ast: Ast, list: i32 }
type AstIdx = { ast: Ast, idx: i32 }
type RetInfo = { ret_idx: i32, p: Parser, ast: Ast, end_ret: i32 }

type Pair = { a: i32, b: i32 }
type Triple = { a: i32, b: i32, c: i32 }
type Quad = { a: i32, b: i32, c: i32, d: i32 }
type Quint = { a: i32, b: i32, c: i32, d: i32, e: i32 }
type Sext = { a: i32, b: i32, c: i32, d: i32, e: i32, f: i32 }
type Sept = { a: i32, b: i32, c: i32, d: i32, e: i32, f: i32, g: i32 }

empty_bytes() -> Bytes = bytes_slice(args(), 0, 0)

empty_table() -> Table = { buf: empty_bytes(), count: 0 }

empty_ast() -> Ast = {
  decls: empty_table(),
  imports: empty_table(),
  bindings: empty_table(),
  type_decls: empty_table(),
  funcs: empty_table(),
  params: empty_table(),
  stmts: empty_table(),
  assigns: empty_table(),
  blocks: empty_table(),
  exprs: empty_table(),
  calls: empty_table(),
  ifs: empty_table(),
  record_lits: empty_table(),
  field_inits: empty_table(),
  unaries: empty_table(),
  binaries: empty_table(),
  literals: empty_table(),
  types: empty_table(),
  field_types: empty_table(),
  paths: empty_table(),
  idents: empty_table(),
  decl_lists: empty_table(),
  param_lists: empty_table(),
  stmt_lists: empty_table(),
  expr_lists: empty_table(),
  field_init_lists: empty_table(),
  field_type_lists: empty_table(),
  ident_lists: empty_table()
}

ast_set_decls(a: Ast, t: Table) -> Ast = {
  decls: t,
  imports: copy a.imports,
  bindings: copy a.bindings,
  type_decls: copy a.type_decls,
  funcs: copy a.funcs,
  params: copy a.params,
  stmts: copy a.stmts,
  assigns: copy a.assigns,
  blocks: copy a.blocks,
  exprs: copy a.exprs,
  calls: copy a.calls,
  ifs: copy a.ifs,
  record_lits: copy a.record_lits,
  field_inits: copy a.field_inits,
  unaries: copy a.unaries,
  binaries: copy a.binaries,
  literals: copy a.literals,
  types: copy a.types,
  field_types: copy a.field_types,
  paths: copy a.paths,
  idents: copy a.idents,
  decl_lists: copy a.decl_lists,
  param_lists: copy a.param_lists,
  stmt_lists: copy a.stmt_lists,
  expr_lists: copy a.expr_lists,
  field_init_lists: copy a.field_init_lists,
  field_type_lists: copy a.field_type_lists,
  ident_lists: copy a.ident_lists
}

